<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base theme — Compose handles all UI; this only sets the splash + window background -->
    <style name="Theme.TelegramDrive" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/brand_surface</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.TelegramDrive.Dark" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/brand_surface_dark</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Splash screen theme (API 12+) -->
    <style name="Theme.TelegramDrive.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/brand_surface</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/brand_primary</item>
        <item name="postSplashScreenTheme">@style/Theme.TelegramDrive</item>
    </style>
</resources>
