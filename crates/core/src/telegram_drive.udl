namespace telegram_drive {
    void init_core(string data_dir);
    
    // Auth
    string request_code(string phone, i32 api_id, string api_hash);
    string sign_in(string code);
    boolean check_password(string password);
    boolean logout();

    // Files
    sequence<string> list_files(i64? folder_id);
    void delete_file(i32 message_id, i64? folder_id);
    
