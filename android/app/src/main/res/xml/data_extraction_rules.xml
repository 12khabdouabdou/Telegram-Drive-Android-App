<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ backup rules. Combined with android:allowBackup="false" in the
  manifest, this prevents both key-value and file backups from leaking
  Telegram session data, API credentials, or any other user state.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
